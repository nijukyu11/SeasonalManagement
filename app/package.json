{
  "name": "app",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test:rules": "node scripts/rule-regression-tests.cjs",
    "test:updater": "node --experimental-strip-types --test src/lib/appUpdater.test.ts",
    "release:repo": "node scripts/configure-release-repo.cjs",
    "release:version": "node scripts/sync-release-version.cjs",
    "check:skawld": "node scripts/check-skawld-sdk.mjs",
    "skawld:dashboard-harness": "node scripts/skawld-dashboard-agent-harness.mjs",
    "test:skawld-dashboard-harness": "node scripts/test-skawld-dashboard-agent-harness.mjs",
    "test:notifications": "node --experimental-strip-types --test src/lib/scheduleNotifications.test.ts",
    "python:agent:install": "python -m pip install -r ai-agent/requirements.txt",
    "python:agent:bundle": "node scripts/build-python-agent.cjs",
    "python:agent:test": "python -m unittest discover -s ai-agent/tests -t ai-agent",
    "python:agent:dev": "python -m uvicorn agent.main:app --app-dir ai-agent --host 127.0.0.1 --port 8765",
    "start": "next start",
    "lint": "eslint",
    "tauri": "tauri",
    "native:dev": "tauri dev",
    "native:build": "tauri build --ci"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "firebase": "^12.12.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@skawld/agent-sdk": "^0.1.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "better-sqlite3": "^11.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
