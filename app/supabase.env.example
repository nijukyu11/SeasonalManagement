# Runtime/native app settings
NEXT_PUBLIC_REMOTE_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Operator-only migration setting. Do not ship this in the native app.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Supabase Edge Function secrets for schedule-telegram-notify.
# Set these with `npx supabase secrets set ...`; do not ship them in the native app.
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_CHAT_ID=<telegram-chat-or-channel-id>
